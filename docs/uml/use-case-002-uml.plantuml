@startuml
left to right direction
actor "Gardener" as AC_G

rectangle "HappyPlant - Plant Care Management" {
    usecase "Generate Care Profile" as UC_GCP
    usecase "Search by Physical Traits" as UC_SPT
    usecase "Identify Plant via Photo" as UC_IPP
}

' Alternative flows for finding the plant or adjusting the profile
UC_SPT .u.> UC_GCP : <<extend>>
UC_IPP .u.> UC_GCP : <<extend>>

' The actor initiates the primary profile generation process
AC_G --> UC_GCP

@enduml