@startuml
hide circle
skinparam classAttributeIconSize 0

class User {
  - name
  - pushNotificationsEnabled
  - quietHoursStart
  - quietHoursEnd
}

class Gardener { }

class Plant {
  - nickname
  - physicalTraits
  - size
  - weight
  - dateAdded
}

class PlantSpecies {
  - scientificName
  - commonName
  - baseSunlight
  - baseWaterFrequency
  - baseNPKLevels
  - optimalHumidity
}

class CareProfile {
  - customizedSunlight
  - customizedWaterFreq
  - customizedNPK
  - environmentalConstraints
}

class WateringLog {
  - timestamp
  - actor 
}

class Reminder {
  - scheduledTime
  - plantFor
  - status
  - snoozeDuration
}

Gardener -- User : inherits > 
Gardener "1" -- "0..*" Plant : owns >
Plant "0..*" -- "1" PlantSpecies : belongs to >
Plant "1" -- "1" CareProfile : possesses >
Plant "1" -- "0..*" WateringLog : maintains >
Plant "1" -- "0..*" Reminder : triggers >

@enduml
