@startuml
left to right direction
actor "Gardener" as AC_G

rectangle "HappyPlant - Plant Care Management" {
    usecase "Process Watering Reminder" as UC_PWR
    usecase "Mark Plant as Watered" as UC_MPW
    usecase "Forward Reminder" as UC_FR
}

' Marking the plant as watered is the standard required step
UC_PWR .r.> UC_MPW : <<include>>

' Alternative flows representing user choices during the reminder process
UC_FR .u.> UC_PWR : <<extend>>

' The actor initiates the interaction with the reminder
AC_G --> UC_PWR

@enduml